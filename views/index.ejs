<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Black List | Kick Hub</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cloudflare.com">
</head>

<body>
    <div class="animated-bg"></div>

    <header class="main-header">
        <img src="/black.png" alt="Logo" class="header-logo">
        <div class="header-btns">
            <button class="plus-btn" onclick="openSocial()">حساباتنا</button>
            <button class="plus-btn" onclick="openModal()">+ أضف قناتك</button>
        </div>
    </header>

    <!-- مربعات الإحصائيات -->
    <div class="stats-container">
        <div class="stat-box">
            <small>إجمالي الستريمرز</small>
            <h2>
                <%= stats.totalStreamers %>
            </h2>
        </div>
        <div class="stat-box">
            <small>مشاهد حالياً</small>
            <h2 style="color: var(--neon-blue);">
                <%= stats.totalViewers %>
            </h2>
        </div>
        <div class="stat-box">
            <small>ستريمر نشط الآن</small>
            <h2 style="color: #53fc18;">
                <%= stats.liveNow %>
            </h2>
        </div>
    </div>

    <!-- منيو الفلترة -->
    <div class="filter-menu">
        <button onclick="filter('high')">الأعلى مشاهدة</button>
        <button onclick="filter('low')">الأقل مشاهدة</button>
        <button onclick="filter('live')">لايف الآن</button>
        <button onclick="filter('offline')">أوفلاين</button>
    </div>

    <div class="cards-grid" id="mainGrid">
        <% streamers.forEach(streamer=> { %>
            <div class="card" data-viewers="<%= streamer.viewers %>" data-live="<%= streamer.isLive %>">
                <i class="fas fa-star star-icon"></i>

                <div class="profile-side" style="display: flex; flex-direction: column; align-items: center;">
                    <img src="<%= streamer.profilePic || '/black.png' %>" class="profile-img">
                    <div style="font-size: 10px; margin-top: 5px; color: #888;">VIEWERS <%= streamer.viewers %>
                    </div>
                </div>

                <div class="info-side">
                    <h3 style="margin: 0;">
                        <%= streamer.kickUsername %>
                    </h3>
                    <% if(streamer.isLive) { %>
                        <div style="color: #ff4b4b; font-size: 12px;"><span class="dot"></span> LIVE</div>
                        <% } %>
                            <a href="https://kick.com<%= streamer.kickUsername %>" target="_blank"
                                class="watch-btn">مشاهدة البث</a>
                </div>
            </div>
            <% }) %>
    </div>

    <!-- مودال الحسابات -->
    <div id="socialModal" class="social-modal">
        <div class="social-content">
            <div style="background: var(--dark-blue); padding: 10px; border-radius: 10px; margin-bottom: 20px;">
                <h3>حسابات عصابة بلاك ليست</h3>
            </div>
            <div class="social-grid">
                <a href="https://x.com/BlackListt_BL?s=20" target="_blank" class="social-box">تويتر X</a>
                <a href="https://discord.gg/KXNVuf8u" target="_blank" class="social-box">ديسكورد</a>
            </div>
            <button onclick="closeSocial()"
                style="margin-top: 20px; background: none; color: gray; border: none; cursor: pointer;">إغلاق</button>
        </div>
    </div>

    <!-- كود المودال والفلترة JS -->
    <script>
        function openSocial() { document.getElementById('socialModal').style.display = 'flex'; }
        function closeSocial() { document.getElementById('socialModal').style.display = 'none'; }

        function filter(type) {
            const cards = Array.from(document.querySelectorAll('.card'));
            const grid = document.getElementById('mainGrid');

            if (type === 'high') cards.sort((a, b) => b.dataset.viewers - a.dataset.viewers);
            if (type === 'low') cards.sort((a, b) => a.dataset.viewers - b.dataset.viewers);

            grid.innerHTML = "";
            cards.forEach(c => {
                if (type === 'live' && c.dataset.live === 'false') return;
                if (type === 'offline' && c.dataset.live === 'true') return;
                grid.appendChild(c);
            });
        }
    </script>
</body>

</html>