<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Black List Hub | Justice Blue</title>
    <!-- تغيير أيقونة التبويب لصورتك -->
    <link rel="icon" type="image/png" href="/black.png">
    <link rel="stylesheet" href="/style.css">
    <!-- مكتبة الأيقونات للنجمة -->
    <link rel="stylesheet" href="https://cloudflare.com">
</head>

<body>

    <!-- الخلفية المتحركة -->
    <div class="animated-bg"></div>

    <header class="main-header">
        <img src="/black.png" alt="Logo" class="header-logo">
        <div class="header-btns">
            <button class="plus-btn" onclick="toggleModal('socialModal')">حساباتنا</button>
            <button class="plus-btn" onclick="toggleModal('addModal')">+ أضف قناتك</button>
        </div>
    </header>

    <!-- شريط الإحصائيات (Justice Style) -->
    <div class="stats-bar">
        <div class="stat-item"><small>إجمالي الستريمرز</small>
            <h3>
                <%= stats.totalStreamers %>
            </h3>
        </div>
        <div class="stat-item"><small>مشاهد حالياً</small>
            <h3>
                <%= stats.totalViewers %>
            </h3>
        </div>
        <div class="stat-item"><small>ستريمر نشط</small>
            <h3 style="color: #53fc18;">
                <%= stats.liveNow %>
            </h3>
        </div>
    </div>

    <!-- منيو الفلترة المنسدل -->
    <div style="text-align: center; margin-bottom: 20px;">
        <select class="filter-select" onchange="runFilter(this.value)">
            <option value="all">جميع القنوات</option>
            <option value="live">البث المباشر 🔴</option>
            <option value="offline">غير متصل 💤</option>
            <option value="fav">المفضلة ⭐</option>
        </select>
    </div>

    <!-- شبكة البطاقات -->
    <div class="cards-grid" id="mainGrid">
        <% streamers.forEach(streamer=> { %>
            <div class="card" id="card-<%= streamer.kickUsername %>" data-live="<%= streamer.isLive %>">
                <!-- نجمة المفضلة -->
                <i class="fas fa-star star-btn" onclick="toggleFav('<%= streamer.kickUsername %>')"></i>

                <div class="profile-side">
                    <img src="<%= streamer.profilePic || '/black.png' %>" class="profile-img">
                    <div class="viewers-tag">VIEWERS <%= streamer.viewers %>
                    </div>
                </div>

                <div class="card-content">
                    <div class="kick-tag">KICK</div>
                    <h3 style="margin: 0; font-size: 20px;">
                        <%= streamer.kickUsername %>
                    </h3>

                    <% if(streamer.isLive) { %>
                        <div class="live-badge">LIVE</div><br>
                        <a href="https://kick.com<%= streamer.kickUsername %>" target="_blank" class="watch-btn">مشاهدة
                            البث</a>
                        <% } else { %>
                            <div style="color: #666; font-size: 12px;">غير متصل</div><br>
                            <a href="https://kick.com<%= streamer.kickUsername %>" target="_blank"
                                class="watch-btn offline">زيارة القناة</a>
                            <% } %>
                </div>
            </div>
            <% }) %>
    </div>

    <!-- مودال الحسابات (بالروابط اللي طلبتها) -->
    <div id="socialModal" class="modal-overlay"
        style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.9); z-index:3000; align-items:center; justify-content:center;">
        <div
            style="background:#111; padding:30px; border-radius:15px; border:2px solid var(--neon-blue); width:320px; text-align:center;">
            <div style="background: var(--dark-blue); padding: 10px; border-radius: 8px; margin-bottom: 20px;">
                <h3 style="margin:0; color:white;">حسابات عصابة بلاك ليست</h3>
            </div>
            <div style="display: grid; gap: 10px;">
                <a href="https://x.com" target="_blank"
                    style="background:#1da1f2; color:white; padding:12px; border-radius:8px; text-decoration:none; font-weight:bold;">تويتر
                    X</a>
                <a href="https://discord.gg" target="_blank"
                    style="background:#5865f2; color:white; padding:12px; border-radius:8px; text-decoration:none; font-weight:bold;">ديسكورد</a>
            </div>
            <button onclick="toggleModal('socialModal')"
                style="margin-top:20px; background:none; color:gray; border:none; cursor:pointer;">إغلاق</button>
        </div>
    </div>

    <!-- مودال أضف قناتك -->
    <div id="addModal" class="modal-overlay"
        style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.9); z-index:3000; align-items:center; justify-content:center;">
        <div
            style="background:#111; padding:30px; border-radius:15px; border:2px solid var(--neon-blue); width:320px; text-align:center;">
            <h3 style="color:var(--neon-blue); margin-bottom:20px;">أضف قناتك للمنصة</h3>
            <form action="/apply" method="POST">
                <input type="text" name="kickUser" placeholder="اسمك في Kick" required
                    style="width:100%; padding:10px; margin-bottom:15px; background:#222; border:none; color:white; border-radius:8px; box-sizing: border-box;">
                <button type="submit" class="watch-btn" style="width:100%; border:none; cursor:pointer;">إرسال
                    الطلب</button>
            </form>
            <button onclick="toggleModal('addModal')"
                style="margin-top:15px; background:none; color:gray; border:none; cursor:pointer;">إلغاء</button>
        </div>
    </div>

    <script>
        // دالة فتح وإغلاق النوافذ
        function toggleModal(id) {
            const m = document.getElementById(id);
            m.style.display = (m.style.display === 'flex') ? 'none' : 'flex';
        }

        // نظام المفضلة (النجمة)
        function toggleFav(user) {
            let favs = JSON.parse(localStorage.getItem('bl_favs')) || [];
            const index = favs.indexOf(user);
            if (index > -1) { favs.splice(index, 1); } else { favs.push(user); }
            localStorage.setItem('bl_favs', JSON.stringify(favs));
            updateStars();
        }

        function updateStars() {
            let favs = JSON.parse(localStorage.getItem('bl_favs')) || [];
            document.querySelectorAll('.card').forEach(c => {
                const user = c.id.replace('card-', '');
                c.querySelector('.star-btn').classList.toggle('active', favs.includes(user));
            });
        }

        // نظام الفلترة (المنيو)
        function runFilter(val) {
            let favs = JSON.parse(localStorage.getItem('bl_favs')) || [];
            document.querySelectorAll('.card').forEach(c => {
                c.style.display = 'flex';
                const user = c.id.replace('card-', '');
                if (val === 'live' && c.dataset.live === 'false') c.style.display = 'none';
                if (val === 'offline' && c.dataset.live === 'true') c.style.display = 'none';
                if (val === 'fav' && !favs.includes(user)) c.style.display = 'none';
            });
        }

        window.onload = updateStars;
    </script>
</body>

</html>